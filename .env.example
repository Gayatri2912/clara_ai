# LLM Configuration
# Choose between OpenRouter (free tier) or Ollama (local)
LLM_PROVIDER=openrouter  # Options: 'openrouter' or 'ollama'

# OpenRouter Configuration (Free Tier)
# Get your free API key from https://openrouter.ai/
# Free models: google/gemini-flash-1.5-8b, google/gemini-flash-1.5
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-flash-1.5-8b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama Configuration (Local, Unlimited Free)
# Install Ollama from https://ollama.ai/
# Run: ollama pull llama2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# n8n Configuration
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_BASIC_AUTH_ACTIVE=false

# Paths
OUTPUT_DIR=outputs/accounts
DATASET_DIR=dataset
TEMPLATES_DIR=templates
DATABASE_PATH=database/accounts.db
LOGS_DIR=logs

# Processing Configuration
MAX_RETRIES=3
RETRY_DELAY=2
TIMEOUT_SECONDS=30

# Debug
DEBUG=false
LOG_LEVEL=INFO
